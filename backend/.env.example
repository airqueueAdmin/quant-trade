# Gemini API 키를 여기에 입력하세요.
# 이 파일의 이름을 .env 로 변경하여 사용하세요.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# NewsAPI 키를 여기에 입력하세요. (https://newsapi.org/ 에서 무료로 발급)
NEWS_API_KEY="YOUR_NEWS_API_KEY"

# Supabase 설정
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
SUPABASE_DB_SCHEMA="public"

# 별도 웹 프론트엔드(Vite/React 등)에서 백엔드를 직접 호출할 때 허용할 Origin 목록
# 쉼표(,)로 여러 개를 구분하세요.
# 예: "http://localhost:4173,http://127.0.0.1:4173,http://localhost:5173,http://127.0.0.1:5173"
CORS_ALLOW_ORIGINS="http://localhost:4173,http://127.0.0.1:4173,http://localhost:5173,http://127.0.0.1:5173"

# Apps in Toss mTLS 인증서
APPS_IN_TOSS_APP_NAME="glance-invest"
APPS_IN_TOSS_CERT_PATH_PEM=""
APPS_IN_TOSS_KEY_PATH_PEM=""
APPS_IN_TOSS_API_BASE_URL="https://apps-in-toss-api.toss.im"
TOSS_LOGIN_ME_URL="https://apps-in-toss-api.toss.im/api-partner/v1/apps-in-toss/user/oauth2/login-me"
